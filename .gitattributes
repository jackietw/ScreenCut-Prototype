# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force bash scripts to always use LF
*.sh text eol=lf

# Explicitly declare Windows-specific scripts to use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.vbs text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.dll binary
*.exe binary
